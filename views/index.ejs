<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Inventario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5">
    <!-- ✅ MOVER LOS BOTONES ARRIBA (estaban abajo en tu código) -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Reporte de Inventario y Stock</h2>
        <div>
            <!-- ✅ Cambiar rutas a las nuevas -->
            <a href="/historial" class="btn btn-secondary me-2">Ver Historial</a>
            <a href="/lotes/nuevo-lote" class="btn btn-primary">+ Registrar Entrada</a>
            <a href="/ventas/nueva-venta" class="btn btn-warning fw-bold">+ Registrar Venta</a>
            <a href="/devoluciones/nueva-devolucion" class="btn btn-danger fw-bold">+ Registrar Devolución</a>
            <!-- ✅ Agregar nuevo botón de productos por vencer -->
            <a href="/por-vencer" class="btn btn-info fw-bold">⚠️ Por Vencer</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Productos</th>
                        <th>Lote</th>
                        <th>SKU</th>
                        <th>Vencimiento</th>
                        <th>Entradas</th>
                        <th>Ventas</th>
                        <th>Devoluciones</th>
                        <th>Stock Actual</th>
                    </tr>
                </thead>
                <tbody>
                    <% inventario.forEach(function(item) { %>
                        <tr class="<%= item['Stock Actual'] <= 5 ? 'table-danger' : '' %>">
                            <td><%= item['Product Name'] %></td>
                            <td><%= item['Lot'] %></td>
                            <td><%= item['Brand Sku Number'] %></td>
                            <td><%= new Date(item['Exp Date']).toLocaleDateString() %></td>
                            <td><%= item['Entradas'] %></td>
                            <td><%= item['Total sold'] %></td>
                            <td><%= item['Returns'] %></td>
                            <td><strong><%= item['Stock Actual'] %></strong>
                                <% if (item['Stock Actual'] <= 5) { %>
                                    <span class="badge bg-danger ms-2">Stock Bajo</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>