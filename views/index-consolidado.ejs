<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventario Consolidado</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        .stock-card {
            border-left: 4px solid;
            margin-bottom: 20px;
            transition: transform 0.2s;
        }
        .stock-card:hover {
            transform: translateY(-5px);
        }
        .stock-critico { border-left-color: #dc3545; }
        .stock-bajo { border-left-color: #ffc107; }
        .stock-normal { border-left-color: #28a745; }
        .total-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
        }
    </style>
</head>
<body class="bg-light">

<div class="container mt-4">
    <!-- Header -->
   <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <div>
            <h2>📦 Inventario Consolidado</h2>
            <% if (user) { %>
                <small class="text-muted">Bienvenido, <strong><%= user.nombre %></strong></small>
            <% } %>
        </div>
        <div class="btn-group">
            <a href="/detalle" class="btn btn-outline-secondary">📋 Ver por Lotes</a>
            <a href="/historial" class="btn btn-outline-info">📜 Historial</a>
            <a href="/vencidos" class="btn btn-outline-danger">⚠️ Vencidos</a>
            <a href="/lotes/nuevo-lote" class="btn btn-primary">➕ Entrada</a>
            <a href="/ventas/nueva-venta" class="btn btn-warning">💰 Venta</a>
            <a href="/devoluciones/nueva-devolucion" class="btn btn-danger">↩️ Devolución</a>
            <a href="/por-vencer" class="btn btn-success">⚠️ Por Vencer</a>
            <a href="/logout" class="btn btn-outline-danger">🚪 Cerrar Sesión</a>
        </div>
    </div>

    <!-- Totales Generales -->
    <% 
    let totalStock = 0;
    let totalProductos = 0;
    for (let nombre in productos) {
        totalStock += productos[nombre].stockTotal;
        totalProductos++;
    }
    %>
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card total-box text-center p-3">
                <h6 class="mb-0">📦 Stock Total</h6>
                <h2 class="mb-0"><%= totalStock %></h2>
                <small>unidades</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card total-box text-center p-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <h6 class="mb-0">🏷️ Productos</h6>
                <h2 class="mb-0"><%= totalProductos %></h2>
                <small>activos</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card total-box text-center p-3" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <h6 class="mb-0">⚠️ Por Vencer</h6>
               <h2 class="mb-0"><%= totalPorVencer %></h2>
                <small>en 30 días</small>
            </div>
        </div>
    </div>

    <!-- Productos -->
    <% for (let [nombre, data] of Object.entries(productos)) { 
        let estadoClass = data.stockTotal <= 5 ? 'stock-critico' : (data.stockTotal <= 20 ? 'stock-bajo' : 'stock-normal');
    %>
        <div class="card stock-card <%= estadoClass %> shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <h4 class="mb-0"><%= nombre %></h4>
                        <small class="text-muted">SKU: <%= data.sku %></small>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="border rounded p-2">
                            <small class="text-muted">STOCK TOTAL</small>
                            <h3 class="mb-0 <%= data.stockTotal <= 5 ? 'text-danger' : 'text-success' %>">
                                <%= data.stockTotal %>
                            </h3>
                        </div>
                    </div>
                   <div class="col-md-4 text-end">
    <!-- Botón Eliminar con opciones -->
    <div class="btn-group me-2">
        <button type="button" 
                class="btn btn-danger btn-sm dropdown-toggle" 
                data-bs-toggle="dropdown" 
                aria-expanded="false">
            🗑️ Eliminar
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#" onclick="eliminarProducto('<%= data.sku %>', 'caducado')">
                ⏰ Producto Caducado
            </a></li>
            <li><a class="dropdown-item" href="#" onclick="eliminarProducto('<%= data.sku %>', 'descatalogado')">
                📦 Producto Descatalogado
            </a></li>
            <li><a class="dropdown-item" href="#" onclick="eliminarProducto('<%= data.sku %>', 'error_registro')">
                ✏️ Error en registro
            </a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="#" onclick="eliminarProducto('<%= data.sku %>', 'permanente')">
                ⚠️ Eliminar permanentemente
            </a></li>
        </ul>
    </div>
    <span class="badge <%= data.stockTotal <= 5 ? 'bg-danger' : 'bg-success' %> fs-6 p-2">
        <%= data.stockTotal <= 0 ? 'AGOTADO' : (data.stockTotal <= 5 ? 'STOCK CRÍTICO' : (data.stockTotal <= 20 ? 'STOCK BAJO' : 'DISPONIBLE')) %>
    </span>
</div>
                </div>
                
                <hr>
                
                <div class="row text-center mb-3">
                    <div class="col-md-4">
                        <div class="alert alert-info mb-0 py-2">
                            📥 Entradas: <strong><%= data.entradasTotales %></strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-warning mb-0 py-2">
                            💰 Ventas: <strong><%= data.ventasTotales %></strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-success mb-0 py-2">
                            🔄 Devoluciones: <strong><%= data.devolucionesTotales %></strong>
                        </div>
                    </div>
                </div>
                
                <details>
                    <summary class="text-muted" style="cursor: pointer;">📋 Ver lotes (<%= data.lotes.length %>)</summary>
                    <table class="table table-sm table-hover mt-2">
                        <thead class="table-light">
                            <tr><th>Lote</th><th>Vence</th><th>Stock</th></tr>
                        </thead>
                        <tbody>
                            <% data.lotes.forEach(lote => { %>
                                <tr>
                                    <td><%= lote.numero %></td>
                                    <td><%= new Date(lote.expiracion).toLocaleDateString() %></td>
                                    <td class="fw-bold"><%= lote.stock %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </details>
            </div>
        </div>
    <% } %>
</div>

<script>
function eliminarProducto(sku, motivo) {
    let mensaje = '';
    let confirmText = '';
    
    switch(motivo) {
        case 'caducado':
            mensaje = '⚠️ ¿Marcar producto como CADUCADO?\n\nEl producto ya no se puede vender.\nSe conservará el historial de ventas.\n\n¿Confirmar?';
            confirmText = 'Marcar como caducado';
            break;
        case 'descatalogado':
            mensaje = '📦 ¿Producto DESCARTALOGADO?\n\nYa no se venderá más este producto.\nSe conservará el historial de ventas.\n\n¿Confirmar?';
            confirmText = 'Marcar como descatalogado';
            break;
        case 'error_registro':
            mensaje = '✏️ Error en registro\n\n¿Seguro que quieres eliminar este producto?\nFue registrado por error.\n\n⚠️ Esta acción NO se puede deshacer.';
            confirmText = 'Eliminar producto erróneo';
            break;
        case 'permanente':
            mensaje = '⚠️ ELIMINACIÓN PERMANENTE\n\n¿Estás seguro?\nEsta acción eliminará el producto y TODOS sus datos.\n\n⚠️ NO se puede deshacer.';
            confirmText = 'Eliminar permanentemente';
            break;
    }
    
    if (confirm(mensaje)) {
        fetch(`/productos/eliminar/${sku}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ motivo: motivo })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('✅ ' + data.message);
                location.reload();
            } else {
                alert('❌ Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('❌ Error al eliminar: ' + error);
        });
    }
}
</script>

</body>
</html>