<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Historial de Movimientos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Historial de Transacciones</h2>
            <!-- ✅ Cambiar ruta a / (ahora es la raíz del inventario) -->
            <a href="/" class="btn btn-outline-dark">← Volver al Inventario</a>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha y Hora</th>
                            <th>Tipo</th>
                            <th>Producto (Lote)</th>
                            <th>Orden #</th>
                            <th>Cantidad</th>
                            <th>Detalle / Motivo</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (historial.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted">No hay movimientos registrados aún.</td>
                            </tr>
                        <% } else { %>
                            <% historial.forEach(function(mov) { %>
                                <tr>
                                    <td><%= new Date(mov.fecha_registro).toLocaleString() %></td>
                                    <td>
                                        <% if (mov.tipo === 'VENTA') { %>
                                            <span class="badge bg-warning text-dark">VENTA</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">DEVOLUCIÓN</span>
                                        <% } %>
                                    </td>
                                    <td><strong><%= mov.producto %></strong> <br><small class="text-muted">Lote: <%= mov.numero_lote %></small></td>
                                    <td><%= mov.numero_orden %></td>
                                    <td class="fw-bold <%= mov.tipo === 'VENTA' ? 'text-danger' : 'text-success' %>">
                                        <%= mov.tipo === 'VENTA' ? '-' : '+' %><%= mov.cantidad %>
                                    </td>
                                    <td><%= mov.motivo_devolucion ? mov.motivo_devolucion : '-' %></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>