<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Productos por Vencer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>⚠️ Productos Próximos a Vencer</h2>
            <a href="/" class="btn btn-outline-dark">← Volver al Inventario</a>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Producto</th>
                            <th>Número de Lote</th>
                            <th>Fecha Expiración</th>
                            <th>Días Restantes</th>
                            <th>Stock Actual</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (productos.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted">No hay productos próximos a vencer</td>
                            </tr>
                        <% } else { %>
                            <% productos.forEach(function(prod) { %>
                                <tr class="<%= prod.dias_restantes <= 15 ? 'table-danger' : 'table-warning' %>">
                                    <td><strong><%= prod.nombre %></strong></td>
                                    <td><%= prod.numero_lote %></td>
                                    <td><%= new Date(prod.fecha_expiracion).toLocaleDateString() %></td>
                                    <td><%= prod.dias_restantes %> días</td>
                                    <td><%= prod.stock_actual %></td>
                                    <td>
                                        <% if (prod.dias_restantes <= 15) { %>
                                            <span class="badge bg-danger">⚠️ URGENTE</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Próximo a vencer</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>