<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registrar Venta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Registrar Nueva Venta</h4>
                    </div>
                    <div class="card-body">
                        <!-- ✅ Cambiar action a la nueva ruta -->
                        <form action="/ventas/nueva-venta" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Número de Orden (Order#)</label>
                                <input type="text" name="numero_orden" class="form-control" placeholder="Ej: 588475" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Producto y Lote</label>
                                <select name="lote_id" class="form-select" required>
                                    <option value="" disabled selected>Selecciona el producto a descontar...</option>
                                    <% lotes.forEach(function(lote) { %>
                                        <option value="<%= lote.lote_id %>">
                                            <%= lote.nombre %> (Lote: <%= lote.numero_lote %>)
                                        </option>
                                    <% }); %>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Cantidad Vendida (Total Sold)</label>
                                <input type="number" name="cantidad" class="form-control" min="1" placeholder="Ej: 5" required>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-warning fw-bold">Confirmar Venta</button>
                                <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>